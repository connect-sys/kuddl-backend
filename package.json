{
  "name": "kuddl-backend",
  "version": "1.0.0",
  "description": "Kuddl Platform Backend - Cloudflare Workers",
  "main": "server.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env development",
    "deploy:production": "wrangler deploy --env production",
    "build": "echo 'Build completed - Wrangler will handle bundling during deployment'",
    "db:migrate": "wrangler d1 execute KUDDL_DB --file=./database/d1-schema.sql",
    "db:migrate:dev": "wrangler d1 execute KUDDL_DB --file=./database/d1-schema.sql --env development",
    "db:seed": "node scripts/seed-database.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@google-cloud/vision": "^4.0.0",
    "@tsndr/cloudflare-worker-jwt": "^2.4.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "itty-router": "^4.0.13",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231025.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/twilio": "^3.19.2",
    "@types/uuid": "^9.0.7",
    "esbuild": "^0.19.5",
    "eslint": "^8.53.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2",
    "vitest": "^0.34.6",
    "wrangler": "^4.54.0"
  },
  "keywords": [
    "kuddl",
    "platform",
    "cloudflare",
    "workers",
    "d1",
    "r2",
    "kv"
  ],
  "author": "Kuddl Team",
  "license": "MIT"
}
