{
  "name": "kuddl-backend",
  "compatibility_date": "2024-09-23",
  "main": "src/worker.js",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "development"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kuddl-development",
      "database_id": "your-database-id"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "kuddl-storage"
    }
  ]
}
