# ==============================================
# KUDDL PLATFORM - ENVIRONMENT CONFIGURATION
# ==============================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-characters

# Cloudflare D1 Database Configuration
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
D1_DATABASE_ID=your-d1-database-id
D1_DATABASE_NAME=kuddl-production

# Cloudflare KV Configuration
KV_NAMESPACE_ID=your-kv-namespace-id
KV_NAMESPACE_BINDING=KUDDL_KV

# Legacy Database Configuration (for migration)
DATABASE_URL=postgresql://kuddl_user:kuddl_password@localhost:5432/kuddl_db
REDIS_URL=redis://localhost:6379

# Frontend URLs
FRONTEND_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ==============================================
# EMAIL SERVICE CONFIGURATION
# ==============================================

# SMTP Configuration (for Auth Service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Resend API (Alternative email service)
RESEND_API_KEY=your-resend-api-key

# ==============================================
# CLOUD STORAGE CONFIGURATION
# ==============================================

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=kuddl-storage
R2_PUBLIC_URL=https://pub-1e2f4d9e2f2d4d4293f0dcf70bdff75a.r2.dev

# ==============================================
# PAYMENT GATEWAY CONFIGURATION
# ==============================================

# Razorpay Configuration
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ==============================================
# NOTIFICATION SERVICES CONFIGURATION
# ==============================================

# Twilio Configuration (SMS & WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid_here
TWILIO_TEST_MODE=true

# Firebase Configuration (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ==============================================
# DEVELOPMENT CONFIGURATION
# ==============================================

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================
# PRODUCTION CONFIGURATION (Uncomment for production)
# ==============================================

# NODE_ENV=production
# LOG_LEVEL=warn
# FRONTEND_URL=https://your-domain.com
# ALLOWED_ORIGINS=https://your-domain.com,https://partner.your-domain.com

# ==============================================
# DOCUMENT VERIFICATION & AI SERVICES
# ==============================================

# Document Verification API (for Aadhaar, PAN, etc.)
DOCUMENT_VERIFICATION_API_KEY=your-verification-api-key
DOCUMENT_VERIFICATION_BASE_URL=https://api.verification-service.com

# AI Image Processing (for document validation)
OPENAI_API_KEY=your-openai-api-key
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# ==============================================
# ADMIN CONFIGURATION
# ==============================================

# Default Admin Credentials (will be created on first run)
ADMIN_EMAIL=admin@kuddl.com
ADMIN_PASSWORD=Admin@123!Kuddl
ADMIN_NAME=Kuddl Administrator

# ==============================================
# OPTIONAL SERVICES
# ==============================================

# Google Maps API (for location services)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Elasticsearch (for advanced search)
# ELASTICSEARCH_URL=http://localhost:9200

# Monitoring & Analytics
# SENTRY_DSN=your-sentry-dsn
# GOOGLE_ANALYTICS_ID=your-ga-id
